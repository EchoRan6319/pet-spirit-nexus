# ============================================================
# 宠智灵境 (Pet Spirit Nexus) - Git 忽略规则
# ============================================================

# ==================== Node.js ====================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ==================== 环境变量（包含密钥，严禁提交）====================
.env
.env.local
.env.*.local

# ==================== 数据库文件 ====================
data/*.db
data/*.db-shm
data/*.db-wal
*.sqlite
*.sqlite3

# ==================== 前端构建输出 ====================
frontend/dist/
frontend/unpackage/
frontend/.hbuilderx/

# ==================== 日志文件 ====================
logs/
*.log

# ==================== 系统文件 ====================
.DS_Store
Thumbs.db
desktop.ini

# ==================== 编辑器/IDE ====================
.vscode/
.idea/
*.swp
*.swo
*~

# ==================== 测试覆盖率 ====================
coverage/
.nyc_output/

# ==================== 临时文件 ====================
tmp/
temp/
*.tmp
